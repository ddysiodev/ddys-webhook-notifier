DDYS_NOTIFY_API_BASE=https://ddys.io/api/v1
DDYS_NOTIFY_PUBLIC_BASE=https://ddys.io
DDYS_NOTIFY_SOURCES=latest,hot
DDYS_NOTIFY_MAX_ITEMS=8
DDYS_NOTIFY_MODE=new

# One JSON array can describe every target.
# DDYS_NOTIFY_TARGETS=[{"type":"discord","url":"https://discord.com/api/webhooks/..."},{"type":"slack","url":"https://hooks.slack.com/services/..."}]

# Or use per-platform variables.
DDYS_NOTIFY_GENERIC_WEBHOOK_URL=
DDYS_NOTIFY_DISCORD_WEBHOOK_URL=
DDYS_NOTIFY_SLACK_WEBHOOK_URL=
DDYS_NOTIFY_DINGTALK_WEBHOOK_URL=
DDYS_NOTIFY_DINGTALK_SECRET=
DDYS_NOTIFY_WECOM_WEBHOOK_URL=
DDYS_NOTIFY_LARK_WEBHOOK_URL=
DDYS_NOTIFY_LARK_SECRET=
DDYS_NOTIFY_TELEGRAM_BOT_TOKEN=
DDYS_NOTIFY_TELEGRAM_CHAT_ID=

DDYS_NOTIFY_RETRIES=2
DDYS_NOTIFY_TIMEOUT_MS=10000
DDYS_NOTIFY_DEDUPE_TTL_SECONDS=1209600
DDYS_NOTIFY_RUN_TOKEN=
